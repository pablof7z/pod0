{
  "schema_version": 1,
  "scan_roots": [
    "App/Sources/App/",
    "App/Sources/AppIntents/",
    "App/Sources/Features/",
    "App/Widget/Sources/"
  ],
  "rules": [
    {"id": "direct-appstate-mutation", "regex": "\\.mutateState(?:\\s*\\(|\\s*\\{)"},
    {"id": "workflow-runtime-access", "regex": "\\bWorkflowRuntime\\b"},
    {"id": "job-store-access", "regex": "\\bJobStore\\b"},
    {"id": "artifact-repository-access", "regex": "\\bArtifactRepository\\b"},
    {"id": "episode-sqlite-access", "regex": "\\bEpisodeSQLiteStore\\b"},
    {"id": "persistence-access", "regex": "\\bPersistence\\b"},
    {"id": "chat-history-store-access", "regex": "\\bChatHistoryStore\\b"},
    {"id": "recall-capability-access", "regex": "\\b(RecallCapabilityService|RecallProviderService)\\b"},
    {"id": "vector-index-access", "regex": "\\bVectorIndex\\b"},
    {"id": "sqlite-import", "regex": "\\bimport\\s+(SQLite3|SQLiteVec)\\b"},
    {"id": "sqlite-call", "regex": "\\bsqlite3_[A-Za-z0-9_]+\\s*\\("},
    {"id": "direct-state-field-assignment", "regex": "\\b(store|appStateStore)\\.state\\.[A-Za-z_][A-Za-z0-9_]*\\s*="}
  ],
  "exceptions": []
}
